+  regularize = 0;
+  extend_domain = 0;
+  regularize_tolerance = 1e-6f;
+  invalidate = false;
+  load_virtual_elements = false;
+  user_fields_ = false;
+  ijk_mesh_nb_parts_ = 1;
+  ijk_virt_layer = 1;
+  export_fields_at_faces_ = 0;
+  regularize_polyedre = 0;
+}
