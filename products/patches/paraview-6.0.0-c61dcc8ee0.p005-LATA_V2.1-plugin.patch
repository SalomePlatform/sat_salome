+template <typename _TYPE_, typename _TYPE2_>
+void fromfloattodouble(const  std::vector<_TYPE_>& data0,  std::vector<_TYPE2_>& data)
+{
+  int s=int(data0.size());
+  data.resize(s);
+  for (int i=0; i<s; i++) { data[i]=(_TYPE2_)data0[i];}
+}
