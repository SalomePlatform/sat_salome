+  TRUSTVect<_TYPE_,_SIZE_>::set_line_size_(n2);
+
+  init_dimensions(dimensions_);
+
+  dimensions_[0] = dimension_tot_0_ = n1;
+  dimensions_[1] = n2;
+
+  this->nb_dim_ = 2;
+
+  assert(verifie_LINE_SIZE());
+}
