+//=============================================================================
+// Function : TruncTailWS
+// Purpose  : Truncates the trailing white-space in the string of given size
+//=============================================================================
+inline void TruncTailWS(char* theStr, int theSize)
+{
+  int i = theSize - 1;
+  while (i > -1 && (theStr[i] == ' ' || theStr[i] == 0))
+    i--;
+  theStr[i + 1] = 0;
+}
