+// .Description: Description of a geometry (= a mesh)
+class LataDBGeometry
+{
+public:
+  LataDBGeometry() { timestep_ = -1; }
+  // Item name
+  Nom name_;
+  // Type of elements
+  Motcle elem_type_;
+  int timestep_;
+};
