+Nom latadb_name_from_type_geo(const med_geometry_type& type_geo)
+{
+  Nom type_elem;
+  switch(type_geo)
+    {
+    case MED_QUAD4:
+      type_elem="Rectangle";
+      break;
+    case MED_HEXA8:
+      type_elem="Hexaedre";
+      break;
+    case MED_TRIA3:
+      type_elem="Triangle";
+      break;
+    case MED_TETRA4:
+      type_elem="Tetraedre";
+      break;
+    case MED_PENTA6:
+      type_elem="Prisme";
+      break;
+    case MED_POLYHEDRON:
+      type_elem="Polyedre";
+      break;
+    case MED_POLYGON:
+      type_elem="Polygone";
+      break;
+    case MED_SEG2:
+      type_elem="Segment";
+      break;
+    case MED_POINT1:
+      type_elem="Point";
+      break;
+    default:
+      Cerr<<"type_geo " << (int)type_geo <<" is not a supported element."<<finl;
+      throw;
+      break;
+    }
+  return type_elem;
+}
