+int Motcle::selftest()
+{
+  Nom un_nom;
+  Motcle un_motcle("PasOk");
+  Motcle un_autre(un_nom);
+  un_nom="Ok";
+  un_motcle=un_nom;
+  un_motcle="Ok";
+  un_motcle=un_autre;
+  return 1;
+}
