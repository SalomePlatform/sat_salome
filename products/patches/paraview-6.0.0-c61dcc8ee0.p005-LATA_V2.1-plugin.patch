+int Entree::jumpOfLines()
+{
+  if(istream_)
+    {
+      int jol = 0;
+      char tmp=(char)istream_->peek();
+      while(isspace(tmp))  //tmp=='\n')
+        {
+          if(tmp=='\n')
+            jol++;
+          istream_->get(tmp);
+          tmp=(char)istream_->peek();
+        }
+      return jol;
+    }
+  return -1;
+}
